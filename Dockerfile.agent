FROM golang:1.26-alpine AS builder

WORKDIR /build

COPY go.mod go.sum* ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o klever-agent ./cmd/agent

FROM alpine:3.20

RUN apk add --no-cache ca-certificates docker-cli

WORKDIR /app
COPY --from=builder /build/klever-agent .

ENTRYPOINT ["/app/klever-agent"]
